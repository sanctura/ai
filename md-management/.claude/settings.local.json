{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash"
    ],
    "deny": [
      "Edit(.env)",
      "Edit(.git/**)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git merge *)",
      "Bash(git cherry-pick *)",
      "Bash(git tag *)",
      "Bash(git stash *)"
    ]
  }
}
